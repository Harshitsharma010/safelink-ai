# SafeLink AI Backend — Environment Variables
# Copy this file to .env and fill in your values

# Port for the Express server (default: 3001)
PORT=3001

# Optional: Anthropic API key for Claude AI explanations
# Get one at: https://console.anthropic.com
# If not set, the app still works with rule-based analysis only
ANTHROPIC_API_KEY=sk-ant-your-key-here
